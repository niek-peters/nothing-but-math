hello
<<<
gcd : N x N -> Z+
gcd(a, b) := {
    a               if b = 0
    gcd(b, a mod b) otherwise
} where a >= b

egcd : N x N -> Z+ x Z x Z
egcd(a, b) := {
    (a, 1, 0)                     if b = 0 
    (g, y, x - floor(a / b) * y)  otherwise
} where a >= b, (g, x, y) := egcd(b, a mod b)

modInv : N x Z+ -> Z+
modInv(a, m) := x mod m
where (g, x, y) := egcd(a, m), g = 1
>>>

ok so hello again

<<<
newtIter : Z+ x Z+ -> Z+
newtIter(n, x) := {
    newtIter(n, y)  if y < x
    x               otherwise
} where y := floor((x + floor(n / x)) / 2)
>>>

