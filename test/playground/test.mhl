hello
<<<
gcd : N x N -> Z+
gcd(a, b) := {
    a               if b = 0
    gcd(b, a mod b) otherwise
} where a >= b

egcd : N x N -> Z+ x Z x Z
egcd(a, b) := {
    (a, 1, 0)                           if b = 0 
    (g, y_1, x_1 - floor(a / b) * y_1)  otherwise
} where a >= b, (g, x_1, y_1) := egcd(b, a mod b)

modInv : N x Z+ -> Z+
modInv(a, m) := x mod m
where (g, x, y) := egcd(a, m), g = 1
>>>