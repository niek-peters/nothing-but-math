% this file tests operator precedence
<<<
% mixing unary & binary operators
a : Z
a := -2 ^ 2

b : Z+
b := (-2) ^ 2

c : Q
c := 1 ^ (-2)   % parser quirk, we require parentheses here

d : Q
d := sqrt 16 / 2

% standard binary arithmetic
e : Z
e := 1 + 2 * 3

f : Z
f := 1 - 2 - 3

g : Z
g := 1 ^ 2 ^ 3

h : Z
h := 10 mod 3 + 1

i : Q
i := 1 + 2 / 3 * 4 / 5 + 6 / 7

% mixing boolean & arithmetic operators
j : B
j := 1 + 2 <= 3 + 4

k : B
k := 1 = 2 /= True

% boolean logic
l : B
l := True or False and False

m : B
m := not False or False

% unary chaining
n : Z
n := sqrt (--9)

o : Z
o := - sqrt sqrt 16

p : B
p := not not True

% and then the final boss
q : Z -> Q
q(x) := {
    x / 5 * (5 * (1 + x) / (-x)^3) + 6  if x > 3
    (1 + (x / 3)) / 4                   otherwise
}
>>>

And all evaluated:
